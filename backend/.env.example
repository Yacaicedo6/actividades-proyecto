# Ejemplo de configuración - Copia este archivo a .env y llena tus credenciales

# Security Configuration
SECRET_KEY=tu_secret_key_aqui
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database Configuration
FRONTEND_URL=http://localhost:5173
DATABASE_URL=postgresql://usuario:contrasena@host:puerto/base_de_datos

# Gmail API Configuration
GMAIL_USER=tu_correo@gmail.com
GMAIL_CLIENT_ID=tu_client_id_de_google_cloud
GMAIL_CLIENT_SECRET=tu_client_secret_de_google_cloud
GMAIL_REFRESH_TOKEN=tu_refresh_token
